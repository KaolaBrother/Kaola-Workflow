{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PLUGIN_ROOT/scripts/kaola-gitlab-workflow-compact-context.js\"",
            "timeout": 5
          }
        ],
        "description": "Inject Kaola-Workflow resume state after context compaction",
        "id": "kaola-workflow:compact-context"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/kaola-workflow-pre-commit.sh\"",
            "timeout": 5
          }
        ],
        "description": "Block commits that mix multiple kaola-workflow project folders",
        "id": "kaola-workflow:pre-commit-guard"
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/kaola-workflow-write-lane.sh\"",
            "timeout": 5
          }
        ],
        "description": "Deny an out-of-lane Write/Edit when write-lane containment is enabled (#376; dormant until a running-set manifest exists)",
        "id": "kaola-workflow:write-lane"
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/kaola-workflow-subagent-dispatch-log.sh\"",
            "timeout": 5
          }
        ],
        "description": "Record subagent spawns (agent_type/agent_id/cwd) to .cache/dispatch-log.jsonl for closure attestation (#277 M1)",
        "id": "kaola-workflow:subagent-dispatch-log"
      }
    ]
  }
}
