# Kaola-Workflow Environment Variables

# Offline mode: set to 1 to run without GitHub API access
# KAOLA_WORKFLOW_OFFLINE=0

# Session identity enforcement: set to 1 to enforce kernel-derived session identity
# (requires kaola-workflow-session-env.js hook to write identity files)
# KAOLA_ENFORCE_PLATFORM_SESSION=

# Kernel session derivation: set to 1 to skip kernel-derived identity and use KAOLA_SESSION_ID directly
# (backward compatibility, direct git usage without Claude Code context)
# KAOLA_KERNEL_SESSION_SKIP=

# Coordination root override: specify custom path for lock/session/ticker state
# (normally auto-discovered via git rev-parse --git-common-dir)
# KAOLA_COORD_ROOT=

# Worktree path: set by claim transaction; used by workflow phases to change directory
# (all workflow phases should check and use this if present)
# KAOLA_WORKTREE_PATH=

# Session ID: auto-derived by kernel walk; fallback if KAOLA_ENFORCE_PLATFORM_SESSION is unset
# KAOLA_SESSION_ID=

# Test-only: override process tree walk for testing derive-session without Claude Code
# KAOLA_KERNEL_SESSION_FAKE_PID=

# Dev/test probe: when set, sink-merge writes final CWD to this file on exit
# Not for production use; used by test suite to verify CWD restoration
# KAOLA_WORKFLOW_DEBUG_CWD=
