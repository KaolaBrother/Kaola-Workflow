# Kaola-Workflow Environment Variables

# Remote call timeout: max milliseconds to wait for GitHub/GitLab/Gitea API responses
# Default 30000 (30 seconds). Set lower in tests to simulate hangs (e.g., 300ms)
# Values above 600000ms (10 minutes) are clamped to 600000ms (issue #185)
# KAOLA_GH_REMOTE_TIMEOUT_MS=30000

# run-chains per-chain kill ceiling: max milliseconds for each spawnSync chain run
# Default 900000 (15 min); invalid/zero/negative falls back to default; no upper clamp (issue #512)
# KAOLA_RUN_CHAINS_TIMEOUT_MS=900000

# Offline mode: set to 1 to run without GitHub API access
# KAOLA_WORKFLOW_OFFLINE=0

# Worktree path: set by claim transaction; used by workflow phases to change directory
# (all workflow phases should check and use this if present)
# KAOLA_WORKTREE_PATH=

# Dev/test probe: when set, sink-merge writes final CWD to this file on exit
# Not for production use; used by test suite to verify CWD restoration
# KAOLA_WORKFLOW_DEBUG_CWD=

# Test-only: fail first N FF attempts in sink-merge (GitHub, GitLab, and Gitea)
# Used by test suite to verify FF race retry logic (exit code 2)
# KAOLA_WORKFLOW_FORCE_FF_FAIL=

# Test-only: force merge-impossible error in sink-merge (GitHub, GitLab, and Gitea)
# Used by test suite to verify fallback to PR sink logic (exit code 3)
# KAOLA_WORKFLOW_FORCE_MERGE_IMPOSSIBLE=

# Worktree-native mode: ON by default — issue claims provision a per-issue repo-local worktree at `<repo-root>/.kw/worktrees/<project>/`. Set to 0 to disable (opt out).
# When on, workflow-next routes to pick-next instead of startup; Phase 4 uses the worktree path for artifacts.
# Provisioning still requires not-offline + git history; otherwise the claim is a repo-root run.
# KAOLA_WORKTREE_NATIVE=0

# Fast-path workflow: set to fast to request single-pass Plan+Execute+Review for small, well-scoped issues
# Defaults to full (6-phase workflow). Fast path requires <=2 closely related files and escalates on scope growth.
# KAOLA_PATH=fast

# Adaptive workflow path (issue #227): set to 1 to enable dynamic-composition routing for a session.
# Overrides the install default; mirrors enable_adaptive:true in ~/.config/kaola-workflow/config.json
# (set by install.sh --enable-adaptive=yes). Default OFF; precedence: env > config > OFF.
# KAOLA_ENABLE_ADAPTIVE=1

# Adaptive fan-out cap: max width of an adaptive fan-out group (governance bound; default 4).
# KAOLA_FANOUT_CAP=

# Test-only: mock script affordance for testing `gh` command execution in claim and sink-merge scripts
# Used by test suite to inject synthetic `gh` behavior without a live GitHub CLI
# KAOLA_GH_MOCK_SCRIPT=

# Test-only: mock scripts for GitLab and Gitea CLI execution in claim/sink scripts
# KAOLA_GLAB_MOCK_SCRIPT=
# KAOLA_TEA_MOCK_SCRIPT=

# Gitea forge adapter: authentication and server URL for Gitea operations
# Required when using the Gitea forge adapter (plugins/kaola-workflow-gitea/)
# GITEA_TOKEN=<your-gitea-access-token>
# GITEA_SERVER_URL=<gitea-server-url>
